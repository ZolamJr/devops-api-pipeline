{
  "name": "devops-api-pipeline",
  "version": "1.0.0",
  "description": "API REST avec pipeline CI/CD complet",
  "main": "app/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node app/server.js",
    "lint": "eslint app/ tests/ --ext .js --max-warnings 0",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "app/**/*.js",
      "!app/server.js"
    ]
  }
}
